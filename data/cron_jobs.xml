<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         CRON: Simulação de Telemetria (AI4I Mock)
         ================================================================ -->
    <record id="cron_simulate_telemetry" model="ir.cron">
        <field name="name">Maintenance Advisor — Simular Telemetria (AI4I Mock)</field>
        <field name="model_id" ref="model_maintenance_telemetry"/>
        <field name="state">code</field>
        <field name="code">env['maintenance.telemetry'].cron_simulate_telemetry()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">False</field>
        <field name="priority">10</field>
    </record>

    <!-- ================================================================
         CRON: Execução de Predições em Lote
         ================================================================ -->
    <record id="cron_run_batch_predictions" model="ir.cron">
        <field name="name">Maintenance Advisor — Executar Predições em Lote</field>
        <field name="model_id" ref="model_maintenance_ai_router"/>
        <field name="state">code</field>
        <field name="code">
env['maintenance.ai.router'].run_batch_predictions(limit=100)
        </field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active">False</field>
        <field name="priority">20</field>
    </record>
</odoo>
